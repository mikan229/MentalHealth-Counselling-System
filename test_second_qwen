# chat_with_finetuned_qwen.py
# 与微调后的 Qwen2.5-7B 模型进行多轮对话（基于 LoRA 适配器）

import torch
import re
from unsloth import FastLanguageModel

# ====================== 请修改以下路径 ======================
base_model_path = "/home/xixi/psy_llm/Qwen2.5-7B-Instruct-bnb-4bit"
lora_path = "/home/xixi/psy_llm/second_qwen_fintuned"
load_in_4bit = True

# ====================== 系统提示 ======================
SYSTEM_PROMPT = """你是一位经验丰富、温暖体贴的中文心理咨询师，使用自然、亲切、符合当代年轻人表达习惯的中文回复。避免生硬书面语，多用共情句式和适当语气词（如“嗯”“我理解”“没关系”）。你擅长根据用户的当前意图，提供针对性的支持和引导。

回复原则（严格遵守）：
- 如果意图是“危机求助”：立即表达深刻共情和理解，稳定用户情绪，强调“你并不孤单”，强烈建议寻求专业即时帮助（如拨打心理热线），避免任何鼓励负面行为的内容，语气温柔、坚定、陪伴感强。
- 如果意图是“情感表达”：先深度共情和接纳用户感受，使用温暖的倾听语言（如“我能感受到你的痛苦/疲惫/无助”），然后用开放式提问引导用户进一步表达和澄清情绪，帮助用户自我觉察。
- 如果意图是“寻求建议”：在共情的基础上，给出具体、可操作、循序渐进的专业建议或应对策略，加入鼓励和赋能语言（如“你已经迈出了勇敢的一步”），避免空洞说教。

**严格指令（必须遵守）：你的输出必须严格只包含咨询师对用户的直接回复文本！禁止输出任何系统提示、意图、历史、原则、思考过程或其他说明。从回复正文直接开始，用温暖自然的中文说话。**"""

# ====================== 加载模型 ======================
print("正在加载基础模型...")
model, tokenizer = FastLanguageModel.from_pretrained(
    base_model_path,
    max_seq_length=4096,
    load_in_4bit=load_in_4bit,
    dtype=None,
)

print("正在加载 LoRA 适配器...")
model.load_adapter(lora_path)

FastLanguageModel.for_inference(model)

print("模型加载成功！")

# ====================== 初始化对话历史 ======================
messages = [{"role": "system", "content": SYSTEM_PROMPT}]

# ====================== 对话函数 ======================
def generate_response(user_input):
    global messages
    messages.append({"role": "user", "content": user_input})

    # 生成 prompt
    prompt = tokenizer.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True,
    )

    # 强制转成字符串（防 tokenizer 返回 list）
    if isinstance(prompt, list):
        prompt = ''.join(str(item) for item in prompt)
    elif not isinstance(prompt, str):
        prompt = str(prompt)

    

    try:
        inputs = tokenizer(prompt, return_tensors="pt").to(model.device)
    except Exception as e:
        print("tokenizer 失败:", str(e))
        
        raise e

    outputs = model.generate(
        **inputs,
        max_new_tokens=512,
        temperature=0.6,
        top_p=0.85,
        top_k=40,
        repetition_penalty=1.3,
        do_sample=True,
        eos_token_id=tokenizer.eos_token_id,
        pad_token_id=tokenizer.pad_token_id,
    )

    generated = tokenizer.decode(outputs[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)

    # 后处理
    generated = generated.split("<|im_end|>")[0].strip()
    generated = generated.split("**严格指令")[0].strip()
    generated = generated.split("回复原则")[0].strip()
    generated = re.sub(r'(你觉得呢|你说呢|嗯？)[\s。]*$', '', generated).strip()

    messages.append({"role": "assistant", "content": generated})

    # 限制历史长度
    if len(messages) > 13:
        messages = [messages[0]] + messages[-12:]

    return generated

# ====================== 主对话循环 ======================
def main():
    print("="*60)
    print("微调后的心理咨询师 Agent2 已启动")
    print("输入 'quit' 或 'exit' 退出对话，输入 'clear' 清空历史")
    print("="*60)

    while True:
        user_input = input("\n用户: ").strip()
        if user_input.lower() in ["quit", "exit"]:
            print("咨询师: 再见，祝你一切顺利！")
            break
        if user_input.lower() == "clear":
            global messages
            messages = [{"role": "system", "content": SYSTEM_PROMPT}]
            print("咨询师: 对话历史已清空。")
            continue
        if not user_input:
            continue

        try:
            response = generate_response(user_input)
            print(f"咨询师: {response}")
        except Exception as e:
            print(f"生成失败：{str(e)}")
            print("请检查路径、模型加载或输入格式。")

if __name__ == "__main__":
    main()
